    aep_srvc_dlvry_id,
    aep_devicecode,
    aep_meter_program,
    aep_srvc_qlty_idntfr,
    name_register,
    aep_sec_per_intrvl,
    aep_endtime_utc,
    aep_acct_cls_cd,
    aep_acct_type_cd,
    aep_city,
    aep_zip,
    aep_state,
