1. Total record count in consume table for today's usage dates:


SELECT aep_usage_dt, COUNT(*) as record_count
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh'
GROUP BY aep_usage_dt
ORDER BY aep_usage_dt;
2. Total record count (should be close to 259,616,581 after dedup):


SELECT COUNT(*) as total_records
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh';
3. Verify incremental table has data:


SELECT aep_opco, COUNT(*) as record_count
FROM xfrm_interval.reading_ivl_nonvee_incr
WHERE aep_opco = 'oh'
GROUP BY aep_opco;
4. Check distinct serial numbers (meters):


SELECT COUNT(DISTINCT serialnumber) as distinct_meters
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh';
5. Sample data check (top 10 rows):


SELECT serialnumber, aep_opco, aep_usage_dt, endtimeperiod, starttimeperiod,
       value, aep_derived_uom, aep_raw_uom, aep_channel_id, aep_meter_bucket
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt = '2026-03-27'
  AND aep_opco = 'oh'
LIMIT 10;
6. Check for NULL serial numbers (data quality):


SELECT COUNT(*) as null_serial_count
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh'
  AND serialnumber IS NULL;
7. Insert vs Update split (hdp_update_user):


SELECT hdp_update_user, COUNT(*) as record_count
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh'
GROUP BY hdp_update_user;
8. Verify old data was deleted from incremental table (older than 8 days):


SELECT MIN(run_date) as oldest_run_date, MAX(run_date) as latest_run_date
FROM xfrm_interval.reading_ivl_nonvee_incr
WHERE aep_opco = 'oh';
9. Check UOM distribution:


SELECT aep_derived_uom, aep_raw_uom, COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh'
GROUP BY aep_derived_uom, aep_raw_uom
ORDER BY cnt DESC;
10. Meter bucket distribution:


SELECT aep_meter_bucket, COUNT(*) as cnt
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt IN ('2026-03-27', '2026-03-26')
  AND aep_opco = 'oh'
GROUP BY aep_meter_bucket
ORDER BY cnt DESC;






