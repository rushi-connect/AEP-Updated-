Step 1: Pick 5 records from DEV that DID match MACS (non-null premise)

-- DEV: Pick 5 records that have premise populated
SELECT 
    serialnumber,
    aep_usage_dt,
    aep_channel_id,
    aep_raw_uom,
    endtimeperiod,
    starttimeperiod,
    value,
    aep_raw_value,
    scalarfloat,
    aep_derived_uom,
    name_register,
    aep_srvc_qlty_idntfr,
    aep_sec_per_intrvl,
    aep_premise_nb,
    aep_service_point,
    aep_srvc_dlvry_id,
    aep_devicecode,
    aep_meter_program,
    aep_acct_cls_cd,
    aep_acct_type_cd,
    aep_mtr_pnt_nb,
    aep_tarf_pnt_nb,
    aep_endtime_utc,
    aep_city,
    aep_zip,
    aep_state,
    authority,
    timezoneoffset,
    aep_meter_bucket,
    hdp_update_user
FROM usage_nonvee.reading_ivl_nonvee_oh
WHERE aep_usage_dt = '2026-03-23'
  AND aep_premise_nb IS NOT NULL
  AND serialnumber IN (
      SELECT DISTINCT serialnumber 
      FROM usage_nonvee.reading_ivl_nonvee_oh 
      WHERE aep_usage_dt = '2026-03-23' 
        AND aep_premise_nb IS NOT NULL 
      LIMIT 5
  )
ORDER BY serialnumber, aep_channel_id, endtimeperiod
LIMIT 50;
