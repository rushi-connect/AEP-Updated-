Prod - Incremental table (reading_ivl_nonvee_incr):


SELECT
    serialnumber, aep_usage_dt, aep_derived_uom, aep_channel_id,
    aep_raw_value, value, aep_service_point, aep_premise_nb
FROM xfrm_interval.reading_ivl_nonvee_incr
WHERE ((hdp_update_dttm >= TIMESTAMP '2026-03-27 00:00:00' AND hdp_update_dttm < TIMESTAMP '2026-03-28 00:00:00')
    OR (hdp_insert_dttm >= TIMESTAMP '2026-03-27 00:00:00' AND hdp_insert_dttm < TIMESTAMP '2026-03-28 00:00:00'))
  AND aep_opco = 'oh'
-- AND serialnumber = '<serial_number>'
